{
  "kind": "collectionType",
  "collectionName": "questions",
  "info": { "singularName": "question", "pluralName": "questions", "displayName": "Question" },
  "options": { "draftAndPublish": true },
  "pluginOptions": { "i18n": { "localized": true } },
  "attributes": {
    "questionId": { "type": "uid", "required": true, "unique": true },
    "text": { "type": "text", "pluginOptions": { "i18n": { "localized": true } }, "required": true },
    "type": { "type": "enumeration", "pluginOptions": { "i18n": { "localized": false } }, "required": true, "enum": ["single_choice", "multiple_choice", "scale", "text", "number", "email", "date", "time"] },
    "category": { "type": "relation", "relation": "manyToOne", "target": "api::section.section", "inversedBy": "questions" },
    "required": { "type": "boolean", "pluginOptions": { "i18n": { "localized": false } }, "default": true },
    "options": { "type": "json", "pluginOptions": { "i18n": { "localized": true } } },
    "depends": { "type": "json", "pluginOptions": { "i18n": { "localized": false } } },
    "order": { "type": "integer", "pluginOptions": { "i18n": { "localized": false } }, "required": true },
    "placeholder": { "type": "text", "pluginOptions": { "i18n": { "localized": true } } },
    "hint": { "type": "text", "pluginOptions": { "i18n": { "localized": true } } },
    "min": { "type": "integer", "pluginOptions": { "i18n": { "localized": false } } },
    "max": { "type": "integer", "pluginOptions": { "i18n": { "localized": false } } },
    "step": { "type": "float", "pluginOptions": { "i18n": { "localized": false } } },
    "unit": { "type": "string", "pluginOptions": { "i18n": { "localized": true } } }
  }
}
