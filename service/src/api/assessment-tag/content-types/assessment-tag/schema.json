{
  "kind": "collectionType",
  "collectionName": "assessment_tags",
  "info": { "singularName": "assessment-tag", "pluralName": "assessment-tags", "displayName": "AssessmentTag" },
  "options": { "draftAndPublish": true },
  "attributes": {
    "name": { "type": "uid", "required": true, "unique": true },
    "text": { "type": "string", "required": true },
    "description": { "type": "text", "required": true },
    "category": { "type": "enumeration", "required": true, "enum": ["sleep", "lifestyle", "work", "student", "special", "behavior", "environment"] },
    "priority": { "type": "enumeration", "required": true, "enum": ["high", "medium", "low"] },
    "severity": { "type": "enumeration", "required": true, "enum": ["mild", "moderate", "severe"] },
    "calc": { "type": "json", "required": true },
    "recommendation": { "type": "json", "required": true }
  }
}
